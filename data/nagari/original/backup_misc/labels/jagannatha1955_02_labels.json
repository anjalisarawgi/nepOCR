        "bounding_box": {
            "x1": 173,
            "y1": 1285,
            "x2": 1724,
            "y2": 1398
        }
    },
    {
        "line_number": 10,
        "text": "वृक्ष अविद्या का उखाड़ता गुरूमन्त्र के सदृश जो ।",
