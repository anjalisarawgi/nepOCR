        }
    },
    {
        "line_number": 2,
        "text": "उत्तमों के लिये वेद का पाठ ही पूजा है, और सोऽहं का जप महा-",
        "image_path": "datasetProcessed/cropped_textlines/images/sankaracarya1925_07_textline_2.png",
