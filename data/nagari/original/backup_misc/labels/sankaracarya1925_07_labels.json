            "y1": 912,
            "x2": 868,
            "y2": 991
        }
    },
    {
        "line_number": 13,
        "text": "अर्थ --- पत्थरों का मंदिर बनाया और फिर पत्थर का ही उसमें",
        "image_path": "datasetProcessed/cropped_textlines/images/sankaracarya1925_07_textline_13.png",
        "bounding_box": {
