            "y1": 1192,
            "x2": 2122,
            "y2": 1345
        }
    },
    {
        "line_number": 12,
        "text": "न तिष्ठति तु य: पूर्वां नोपास्ते यश्च पश्चिमाम् ।",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_08_textline_12.png",
        "bounding_box": {
            "x1": 162,
            "y1": 1453,
            "x2": 2023,
            "y2": 1639
        }
    },
    {
        "line_number": 13,
        "text": "स शुद्रवद्वहिष्कार्य: सर्वस्माद् द्विजकर्मण: ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_08_textline_13.png",
        "bounding_box": {
