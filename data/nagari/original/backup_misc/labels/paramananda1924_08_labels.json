            "y1": 2563,
            "x2": 2072,
            "y2": 2730
        }
    },
    {
        "line_number": 15,
        "text": "हीन ब्राह्मण निष्फल है । यदि जाति करके ही कल्याण होता,",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_08_textline_15.png",
        "bounding_box": {
            "x1": 37,
            "y1": 2710,
            "x2": 2054,
            "y2": 2863
