        "bounding_box": {
            "x1": 68,
            "y1": 436,
            "x2": 2094,
            "y2": 589
        }
    },
    {
        "line_number": 5,
        "text": "निषेध-वाक्य किसलिये कहे गए हैं ।",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_08_textline_5.png",
        "bounding_box": {
            "x1": 79,
            "y1": 569,
            "x2": 1221,
            "y2": 720
        }
    },
    {
        "line_number": 6,
        "text": "ने भी कहा है --",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_08_textline_6.png",
        "bounding_box": {
            "x1": 60,
            "y1": 1317,
            "x2": 648,
            "y2": 1443
        }
    },
    {
        "line_number": 7,
        "text": "अहरह: संध्यामुपासीत ।",
