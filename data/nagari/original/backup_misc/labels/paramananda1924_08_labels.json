            "y1": 1623,
            "x2": 1847,
            "y2": 1797
        }
    },
    {
        "line_number": 14,
        "text": "निष्फल है और जैसे मूर्ख के प्रति दान निष्फल है, वैसे वेद से",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_08_textline_14.png",
        "bounding_box": {
