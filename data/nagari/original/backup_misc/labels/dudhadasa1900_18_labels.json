        "bounding_box": {
            "x1": 104,
            "y1": 599,
            "x2": 1733,
            "y2": 717
        }
    },
    {
        "line_number": 8,
        "text": "जहँ जहँ जाय यज्ञबर बाजू । मिलहिंभूपतहँ सहितसमाजू ॥",
