            "y2": 418
        }
    },
    {
        "line_number": 5,
        "text": "देहातीतंसदाकारं सुददर्शभवादृशैः ।। ३० ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_5.png",
        "bounding_box": {
            "x1": 341,
