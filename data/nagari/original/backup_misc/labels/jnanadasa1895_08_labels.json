            "y2": 559
        }
    },
    {
        "line_number": 6,
        "text": "अहंशब्देनविख्यातएकएवःस्थितःपरः ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_6.png",
        "bounding_box": {
            "x1": 331,
            "y1": 546,
            "x2": 1662,
            "y2": 685
        }
    },
    {
        "line_number": 7,
        "text": "स्थूलत्वनैकतांप्राप्तः कथंस्याद्देहकःपुमान् ।। ३१ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_7.png",
        "bounding_box": {
            "x1": 331,
            "y1": 676,
            "x2": 1961,
            "y2": 834
        }
    },
    {
        "line_number": 8,
        "text": "अहंदृष्टतयासिद्धो देहोदृश्यतयास्थितः ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_8.png",
        "bounding_box": {
