    },
    {
        "line_number": 4,
        "text": "स्वात्मानंशृणुमूर्खत्वं श्रुत्यायुक्त्याचपुरुषम् ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_4.png",
