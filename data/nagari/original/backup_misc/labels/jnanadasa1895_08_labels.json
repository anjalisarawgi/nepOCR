            "y1": 815,
            "x2": 1676,
            "y2": 960
        }
    },
    {
        "line_number": 9,
        "text": "समायमितिनिर्द्देशात्कथंस्याद्देहकःपुमान् ।। ३२ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_9.png",
        "bounding_box": {
            "x1": 319,
            "y1": 954,
            "x2": 1912,
            "y2": 1106
        }
    },
    {
        "line_number": 10,
        "text": "अहंविकारहीनस्तु देहोनित्यविकारवान् ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_10.png",
        "bounding_box": {
            "x1": 325,
            "y1": 1105,
            "x2": 1658,
            "y2": 1230
        }
    },
    {
        "line_number": 11,
        "text": "इतिप्रतीयतेसाक्षात्कथंस्याद्देहकःपुमान् ।। ३३ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_11.png",
        "bounding_box": {
            "x1": 328,
            "y1": 1235,
            "x2": 1888,
            "y2": 1374
        }
    },
    {
        "line_number": 12,
        "text": "यस्मात्परमितिश्रुत्वा तयापुरुषलक्षणम् ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_08_textline_12.png",
        "bounding_box": {
