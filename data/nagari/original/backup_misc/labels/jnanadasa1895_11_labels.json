            "y1": 1305,
            "x2": 1731,
            "y2": 1447
        }
    },
    {
        "line_number": 11,
        "text": "ब्रह्मणःसर्वभूतानि जायंतेपरमात्मनः ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_11.png",
        "bounding_box": {
