            "y1": 1163,
            "x2": 1640,
            "y2": 1309
        }
    },
    {
        "line_number": 10,
        "text": "इहपश्यतिनानात्वंमाययावंचितोनरः ।। ४८ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_10.png",
        "bounding_box": {
