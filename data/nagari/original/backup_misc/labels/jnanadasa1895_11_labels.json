    {
        "line_number": 3,
        "text": "उपादानंप्रपंचस्य ब्रह्मणोन्यन्नविद्यते ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_3.png",
