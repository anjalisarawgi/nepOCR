            "x1": 235,
            "y1": 338,
            "x2": 1552,
            "y2": 496
        }
    },
    {
        "line_number": 4,
        "text": "तस्मात्सर्वप्रपंचोयंब्रह्मैवास्तिनचेतरत् ।। ४५ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_4.png",
        "bounding_box": {
            "x1": 232,
            "y1": 483,
            "x2": 1779,
            "y2": 639
        }
    },
    {
        "line_number": 5,
        "text": "व्याप्यव्यापकतामिथ्या सर्वमात्मेतिशासनात् ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_5.png",
        "bounding_box": {
            "x1": 244,
            "y1": 622,
            "x2": 1764,
            "y2": 777
        }
    },
    {
        "line_number": 6,
        "text": "इतिज्ञातेपरेतत्त्वे भेदस्यावसरःकुतः ।। ४६ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_6.png",
        "bounding_box": {
            "x1": 250,
            "y1": 764,
            "x2": 1713,
            "y2": 906
        }
    },
    {
        "line_number": 7,
        "text": "श्रुत्यानिवारितंनूनं नानात्वंस्वमुखेनहि ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_7.png",
        "bounding_box": {
            "x1": 262,
            "y1": 894,
            "x2": 1555,
            "y2": 1042
        }
    },
    {
        "line_number": 8,
        "text": "कथंभासोभवेदन्यः स्थितेचाद्वयकारणे ।। ४७ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_8.png",
        "bounding_box": {
            "x1": 250,
            "y1": 1021,
            "x2": 1806,
            "y2": 1173
        }
    },
    {
        "line_number": 9,
        "text": "दोषापिविहितःश्रुत्या मृत्योमृत्युंसगच्छति ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_11_textline_9.png",
        "bounding_box": {
