            "y1": 166,
            "x2": 1721,
            "y2": 276
        }
    },
    {
        "line_number": 4,
        "text": "जो सेवकहि रजायसु होई । पद शिरनाय करी प्रभू सोई ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_10_textline_4.png",
