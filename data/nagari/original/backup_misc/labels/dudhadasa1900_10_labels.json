            "x1": 114,
            "y1": 354,
            "x2": 1718,
            "y2": 477
        }
    },
    {
        "line_number": 6,
        "text": "जबलग जीव रहै तनस्वामी । तबलगमोहिंजान्योअनुगामी॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_10_textline_6.png",
        "bounding_box": {
