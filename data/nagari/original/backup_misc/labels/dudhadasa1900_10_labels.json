            "y1": 546,
            "x2": 1716,
            "y2": 658
        }
    },
    {
        "line_number": 8,
        "text": "जो प्रभुकहों कपट छल राखी । ईश सजाय देहिंशिव साखी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_10_textline_8.png",
        "bounding_box": {
