            "y2": 373
        }
    },
    {
        "line_number": 5,
        "text": "जो न करों आयसु रघुनाथा । तौ न धरों धनुशायक हाथा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_10_textline_5.png",
