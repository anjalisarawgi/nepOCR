            "y1": 297,
            "x2": 1908,
            "y2": 480
        }
    },
    {
        "line_number": 4,
        "text": "को न मिटेउ हरिजनहिं सताई ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/pyarelala1914_10_textline_4.png",
