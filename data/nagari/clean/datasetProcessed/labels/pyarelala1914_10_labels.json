        "bounding_box": {
            "x1": 275,
            "y1": 632,
            "x2": 1922,
            "y2": 751
        }
    },
    {
        "line_number": 6,
        "text": "भक्तन सतसंग ढंग शुभ प्रभु बिमुखन",
