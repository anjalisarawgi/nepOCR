        "bounding_box": {
            "x1": 224,
            "y1": 2110,
            "x2": 1941,
            "y2": 2260
        }
    },
    {
        "line_number": 9,
        "text": "दो० हे मन मूरख बावरे, कर रघुबर सों नेह । ",
        "image_path": "datasetProcessed/cropped_textlines/images/pyarelala1914_10_textline_9.png",
        "bounding_box": {
