        "bounding_box": {
            "x1": 353,
            "y1": 903,
            "x2": 1728,
            "y2": 1038
        }
    },
    {
        "line_number": 9,
        "text": "यःसंतिष्ठतिमूढ़ात्माभयंतस्याभिभाषितम् ।। ५२ ।।",
