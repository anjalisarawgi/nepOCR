    {
        "line_number": 13,
        "text": "नवैतस्यभवेन्मोहोनचशोकोद्वितीयतः ।। ५४ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_13.png",
