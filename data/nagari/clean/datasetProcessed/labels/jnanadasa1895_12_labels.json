    },
    {
        "line_number": 21,
        "text": "जबै यह जानौ । नहीं और तहँ निश्चय मानौ ५३ जब सब भूत",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_21.png",
