        "bounding_box": {
            "x1": 353,
            "y1": 1030,
            "x2": 2012,
            "y2": 1183
        }
    },
    {
        "line_number": 10,
        "text": "यत्राज्ञानाद्भवेद्वैतमितरस्तत्रपश्यति ।",
