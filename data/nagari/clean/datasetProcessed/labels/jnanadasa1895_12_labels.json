            "y2": 330
        }
    },
    {
        "line_number": 5,
        "text": "कर्माण्यपिसमग्राणि विभर्तीतिश्रुतिर्जगौ ।। ५० ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_5.png",
        "bounding_box": {
            "x1": 362,
            "y1": 489,
            "x2": 1979,
            "y2": 636
        }
    },
    {
        "line_number": 6,
        "text": "सुवर्णाज्जायमानस्यसुवर्णत्वंचशास्वतम् ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_6.png",
        "bounding_box": {
