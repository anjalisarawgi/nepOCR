            "x1": 262,
            "y1": 1936,
            "x2": 2024,
            "y2": 2068
        }
    },
    {
        "line_number": 15,
        "text": "नाम रूप सब बिबिध सुजोई । ब्रह्म बिना कछु औरनहोई ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_15.png",
        "bounding_box": {
            "x1": 365,
            "y1": 1813,
            "x2": 2027,
            "y2": 1957
        }
    },
    {
        "line_number": 16,
        "text": "५० सुबरण ते उपज्यो है जौन । सो निश्चय सुबरण है तौन ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_16.png",
