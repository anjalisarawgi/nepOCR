            "y1": 634,
            "x2": 1743,
            "y2": 771
        }
    },
    {
        "line_number": 7,
        "text": "ब्रह्मणोजायमानस्य ब्रह्मत्वंचतथाभवेत् ।। ५१ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_12_textline_7.png",
        "bounding_box": {
            "x1": 362,
            "y1": 767,
            "x2": 1927,
            "y2": 906
        }
    },
    {
        "line_number": 8,
        "text": "स्वल्पमप्यंतरंकृत्वा जीवात्मपरमात्मनोः ।",
