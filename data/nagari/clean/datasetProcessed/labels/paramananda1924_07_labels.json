        "bounding_box": {
            "x1": 94,
            "y1": 1234,
            "x2": 2051,
            "y2": 1395
        }
    },
    {
        "line_number": 11,
        "text": "किं कुलं व्रतहीनस्य करिष्यति दुरात्मनः ।",
