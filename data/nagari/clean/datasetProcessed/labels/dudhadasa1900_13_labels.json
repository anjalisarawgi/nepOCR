            "y2": 195
        }
    },
    {
        "line_number": 2,
        "text": "सो० विधि असकरतब कीन्ह हस्यो बुद्धि पुरलोग सब ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_13_textline_2.png",
