            "y1": 2153,
            "x2": 1701,
            "y2": 2272
        }
    },
    {
        "line_number": 24,
        "text": "सुनि खगेश के बचन अनूपा । साधुसाधु कह बायस भूपा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_13_textline_24.png",
