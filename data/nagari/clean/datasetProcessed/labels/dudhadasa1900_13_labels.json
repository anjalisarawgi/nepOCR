            "y1": 2244,
            "x2": 1704,
            "y2": 2365
        }
    },
    {
        "line_number": 25,
        "text": "प्रश्न तुम्हार नाथ म्वहिं भाई । चाहहु सुनन रामप्रभुताई ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_13_textline_25.png",
