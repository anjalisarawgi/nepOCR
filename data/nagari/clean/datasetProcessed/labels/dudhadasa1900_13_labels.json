            "y1": 1862,
            "x2": 1703,
            "y2": 1988
        }
    },
    {
        "line_number": 21,
        "text": "शारद शेष देव मुनि वृन्दा । सेवहिं चरणत्यागिछलछन्दा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_13_textline_21.png",
