        "bounding_box": {
            "x1": 68,
            "y1": 1765,
            "x2": 1693,
            "y2": 1894
        }
    },
    {
        "line_number": 20,
        "text": "जासु दृष्टि जग यावत माया । होहिं नाथ परिपूरण काया ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_13_textline_20.png",
