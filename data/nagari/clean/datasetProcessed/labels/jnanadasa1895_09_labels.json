            "x1": 214,
            "y1": 438,
            "x2": 1898,
            "y2": 599
        }
    },
    {
        "line_number": 5,
        "text": "असंगपुरुषःप्रोक्तो बृहदारण्यकेपिच ।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_09_textline_5.png",
        "bounding_box": {
            "x1": 195,
            "y1": 583,
            "x2": 1446,
            "y2": 729
        }
    },
    {
        "line_number": 6,
        "text": "अनन्तमलसंश्लिष्टः कथंस्याद्देहकःपुमान् ।। ३६ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/jnanadasa1895_09_textline_6.png",
        "bounding_box": {
            "x1": 195,
            "y1": 710,
            "x2": 1909,
            "y2": 873
        }
    },
    {
        "line_number": 7,
        "text": "तत्रैवचसमाख्यातः स्वयंज्योतिर्हिपूरुषः ।",
