            "y1": 1591,
            "x2": 1708,
            "y2": 1708
        }
    },
    {
        "line_number": 20,
        "text": "सुनि प्रभुवचन भरत रणधीरा । भयो विकल लोचनबहनीरा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_20.png",
