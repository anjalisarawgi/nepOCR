    },
    {
        "line_number": 24,
        "text": "आयसु नाथकरों शिर राखी । फिरनअवधआवोंअसभाखी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_24.png",
