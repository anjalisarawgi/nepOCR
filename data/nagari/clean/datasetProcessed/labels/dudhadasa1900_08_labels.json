    },
    {
        "line_number": 23,
        "text": "सियको कहा दोष प्रभुलाई । जो असप्रणकरिमोहिंसुनाई ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_23.png",
        "bounding_box": {
