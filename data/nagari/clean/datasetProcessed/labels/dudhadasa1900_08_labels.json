            "y1": 1512,
            "x2": 1703,
            "y2": 1615
        }
    },
    {
        "line_number": 19,
        "text": "दूत वचन सुनिकै निजकाना । ताते असप्रण अब मैं ठाना ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_19.png",
