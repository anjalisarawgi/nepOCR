            "y1": 1690,
            "x2": 1706,
            "y2": 1798
        }
    },
    {
        "line_number": 21,
        "text": "हृदयशोच मुख आव न बानी । समय देखि कछुकह्योभवानी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_21.png",
