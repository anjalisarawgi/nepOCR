            "y2": 200
        }
    },
    {
        "line_number": 3,
        "text": "भरत लषण रिपुसूदन बीरा । आये जहँ राजित रघुबीरा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_3.png",
