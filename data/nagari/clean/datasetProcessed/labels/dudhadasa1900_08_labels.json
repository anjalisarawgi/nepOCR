    },
    {
        "line_number": 25,
        "text": "कह करजोरि शपथ प्रभुतोरी । मैं नहिं आउब अवधबहोरी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_25.png",
