            "y1": 1411,
            "x2": 1713,
            "y2": 1525
        }
    },
    {
        "line_number": 18,
        "text": "सकहु तो तात पठैबनआवहु । भेदन यहतुमसियहिसुनावहु ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_08_textline_18.png",
