            "y2": 1302
        }
    },
    {
        "line_number": 6,
        "text": "की प्राप्ति और मुक्ति होती है ; और कर्मयोगी कहते हैं कि कर्मों",
        "image_path": "datasetProcessed/cropped_textlines/images/paramananda1924_02_textline_6.png",
