            "x2": 1057,
            "y2": 1599
        }
    },
    {
        "line_number": 25,
        "text": "दूत चारि प्रभुलीन बुलाई । बोले वचन मधुर जलशाई ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_25.png",
