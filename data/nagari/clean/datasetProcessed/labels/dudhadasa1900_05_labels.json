            "y2": 201
        }
    },
    {
        "line_number": 2,
        "text": "अवधचलबजबअवधिसिराई । तुम्हैं विपिनसँग लषणपठाई ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_2.png",
        "bounding_box": {
            "x1": 121,
            "y1": 166,
            "x2": 1716,
            "y2": 288
        }
    },
    {
        "line_number": 3,
        "text": "विधिवत पूज्यो सुरमुनि पाऊ । रहै न फिर कछुमन पछिताऊ ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_3.png",
        "bounding_box": {
            "x1": 131,
            "y1": 273,
            "x2": 1713,
            "y2": 387
        }
    },
    {
        "line_number": 4,
        "text": "जबलग साध कस्यो बनबासू । ह्वैहै सबविधि तुम्हैं सुपासू ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_4.png",
        "bounding_box": {
            "x1": 119,
            "y1": 366,
            "x2": 1716,
            "y2": 478
        }
    },
    {
        "line_number": 5,
        "text": "दो० सुनिप्रभु वचन विनीतअति जनकसुताखगनाथ ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_5.png",
        "bounding_box": {
            "x1": 164,
            "y1": 452,
            "x2": 1574,
            "y2": 572
        }
    },
    {
        "line_number": 6,
        "text": "चरण सरोरुह नाथ निज मुदित नवायो माथ ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_6.png",
        "bounding_box": {
            "x1": 316,
            "y1": 546,
            "x2": 1574,
            "y2": 663
        }
    },
    {
        "line_number": 7,
        "text": "असकहि विपिनचले रघुबीरा । सीता सहित अनुज रणधीरा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_7.png",
        "bounding_box": {
            "x1": 124,
            "y1": 639,
            "x2": 1730,
            "y2": 760
        }
    },
    {
        "line_number": 8,
        "text": "बनबसि चरित कीन्ह भगवाना । सो खगेश नहिं जायबखाना ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_8.png",
        "bounding_box": {
            "x1": 124,
            "y1": 735,
            "x2": 1721,
            "y2": 856
        }
    },
    {
        "line_number": 9,
        "text": "सोकिसकैं अब कहि बागीशा । शारद कोटिन कोटि अहीशा ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_9.png",
        "bounding_box": {
            "x1": 124,
            "y1": 829,
            "x2": 1716,
            "y2": 950
        }
    },
    {
        "line_number": 10,
        "text": "कौन लेख तहँ चेरे दासू । प्रभुपदप्रीति न दृढ़ बिश्वासू ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_10.png",
        "bounding_box": {
            "x1": 129,
            "y1": 925,
            "x2": 1721,
            "y2": 1042
        }
    },
    {
        "line_number": 11,
        "text": "बीते अवधि अवध प्रभुआये । सुनहु उमा सो चरित सुहाये ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_11.png",
        "bounding_box": {
            "x1": 129,
            "y1": 1011,
            "x2": 1721,
            "y2": 1143
        }
    },
    {
        "line_number": 12,
        "text": "आयसु पाय केकयी माता । बैठे राज्य राम सुरत्राता ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_12.png",
        "bounding_box": {
            "x1": 129,
            "y1": 1120,
            "x2": 1721,
            "y2": 1235
        }
    },
    {
        "line_number": 13,
        "text": "पुरजन आय भेंट धरि आगे । बोले वचन प्रेम रस पागे ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_13.png",
        "bounding_box": {
            "x1": 129,
            "y1": 1208,
            "x2": 1721,
            "y2": 1321
        }
    },
    {
        "line_number": 14,
        "text": "नाथ आज बड़ि भाग्य हमारी । चरणकमलरजनयन निहारी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_14.png",
        "bounding_box": {
            "x1": 124,
            "y1": 1302,
            "x2": 1721,
            "y2": 1410
        }
    },
    {
        "line_number": 15,
        "text": "सुरनर असुर नाग मुनिदेवा । मिलिमिलिगयेन जान्योभेवा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_15.png",
        "bounding_box": {
            "x1": 129,
            "y1": 1398,
            "x2": 1721,
            "y2": 1511
        }
    },
    {
        "line_number": 16,
        "text": "नहिं भेवकोऊ जान मिलि प्रभु देव मुनि हरषित चले ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_16.png",
        "bounding_box": {
