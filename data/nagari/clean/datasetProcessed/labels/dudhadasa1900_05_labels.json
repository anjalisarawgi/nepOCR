    },
    {
        "line_number": 26,
        "text": "देशकोश पुर कुशल भुलाई । निशिदिनमोहिं सुनावहुआई ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_26.png",
