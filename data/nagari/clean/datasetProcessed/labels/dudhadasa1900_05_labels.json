            "y1": 1585,
            "x2": 1653,
            "y2": 1709
        }
    },
    {
        "line_number": 17,
        "text": "तब आय ब्रह्मा कीन अस्तुति जोरि युगबानी भले ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_17.png",
        "bounding_box": {
            "x1": 225,
            "y1": 1674,
            "x2": 1632,
            "y2": 1791
        }
    },
    {
        "line_number": 18,
        "text": "अब नाथ चलिये लोक निज बहुभांति नर लीलाकरी ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_18.png",
        "bounding_box": {
            "x1": 218,
            "y1": 1767,
            "x2": 1652,
            "y2": 1882
        }
    },
    {
        "line_number": 19,
        "text": "मुनि देवतनकी बन्दि छोरी भार सब बसुधा हरी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_19.png",
        "bounding_box": {
            "x1": 228,
            "y1": 1858,
            "x2": 1637,
            "y2": 1971
        }
    },
    {
        "line_number": 20,
        "text": "सो० सुनि चतुरानन बैन प्रेम लपेटे रसभरे ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_20.png",
        "bounding_box": {
            "x1": 175,
            "y1": 1960,
            "x2": 1546,
            "y2": 2075
        }
    },
    {
        "line_number": 21,
        "text": "दो० रहे उमा हमहूं वहां देखा सकल समाज ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_05_textline_21.png",
        "bounding_box": {
            "x1": 180,
            "y1": 2152,
            "x2": 1580,
            "y2": 2263
        }
    },
    {
        "line_number": 22,
        "text": "विहँसे राजिवनैन उतर दीन्ह क्वउ जाननहिं ।। ",
