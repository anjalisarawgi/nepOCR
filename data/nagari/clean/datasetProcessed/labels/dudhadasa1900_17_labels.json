            "y1": 612,
            "x2": 1629,
            "y2": 747
        }
    },
    {
        "line_number": 8,
        "text": "बेगि तुरँग सुरनाथ मँगाई । पूजा कीन्ह वेद यश गाई ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_17_textline_8.png",
