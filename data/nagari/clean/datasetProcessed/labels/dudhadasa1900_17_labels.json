            "y1": 713,
            "x2": 1629,
            "y2": 831
        }
    },
    {
        "line_number": 9,
        "text": "हेमपत्र बांध्यो हय शीशा । बांचतज्यहि कोपैं अवनीशा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_17_textline_9.png",
