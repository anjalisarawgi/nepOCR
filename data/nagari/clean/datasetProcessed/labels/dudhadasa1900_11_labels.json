            "y1": 758,
            "x2": 1726,
            "y2": 893
        }
    },
    {
        "line_number": 9,
        "text": "देखिबिपिनघनअतिआँधियारी । केहरिनाद करैं जहँ भारी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_11_textline_9.png",
