    },
    {
        "line_number": 25,
        "text": "प्रभु सिय हृदय मनोरथ जाना । बोलेबिहँसि राम भगवाना ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_25.png",
        "bounding_box": {
