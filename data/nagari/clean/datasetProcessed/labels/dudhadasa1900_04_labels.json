    },
    {
        "line_number": 14,
        "text": "अतिअपारप्रियगतिजगदीशा । को जानै कह अस गौरीशा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_14.png",
