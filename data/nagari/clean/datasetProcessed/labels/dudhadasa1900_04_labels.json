            "y2": 203
        }
    },
    {
        "line_number": 3,
        "text": "प्रथमजोकहसियविपिननिकारी । सुनि संदेह भयो उर भारी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_3.png",
        "bounding_box": {
            "x1": 101,
            "y1": 164,
            "x2": 1689,
            "y2": 291
        }
    },
    {
        "line_number": 4,
        "text": "क्यहि कारण प्रभु दीनसनेही । दीन्ह्यो बास विपिन बैदेही ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_4.png",
        "bounding_box": {
            "x1": 106,
            "y1": 273,
            "x2": 1689,
            "y2": 388
        }
    },
    {
        "line_number": 5,
        "text": "का अपराध जानकी कीन्हा । कृपासिंधुजेहिलगिबनदीन्हा॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_5.png",
        "bounding_box": {
            "x1": 111,
            "y1": 358,
            "x2": 1694,
            "y2": 483
        }
    },
    {
        "line_number": 6,
        "text": "भयो शोच प्रभुशोच निबेरी । कहो बुझाय जानिम्वहिंचेरी॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_6.png",
        "bounding_box": {
            "x1": 119,
            "y1": 450,
            "x2": 1689,
            "y2": 575
        }
    },
    {
        "line_number": 7,
        "text": "यावत नभ विधि विष्णुपुरारी । प्रथमलीकजगअवनिकुमारी॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_7.png",
        "bounding_box": {
            "x1": 114,
            "y1": 547,
            "x2": 1689,
            "y2": 670
        }
    },
    {
        "line_number": 8,
        "text": "जासु दृष्टि उपजैं गुण खानी । कोटिन रमा उमा ब्रह्मानी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_8.png",
        "bounding_box": {
            "x1": 121,
            "y1": 646,
            "x2": 1692,
            "y2": 756
        }
    },
    {
        "line_number": 9,
        "text": "इन्द्रबधू सुर मुनि ऋषिनारी । सदा जासु रुखरहैं निहारी ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_9.png",
        "bounding_box": {
            "x1": 119,
            "y1": 738,
            "x2": 1692,
            "y2": 851
        }
    },
    {
        "line_number": 10,
        "text": "त्यागन विपिन योगनहिं सीता । महादेवकह विधि विपरीता ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_10.png",
