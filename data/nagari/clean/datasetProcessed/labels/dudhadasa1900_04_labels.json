    },
    {
        "line_number": 13,
        "text": "असकछु दशाविलोकि भवानी । बोले हर प्रिय कोमलबानी ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_13.png",
