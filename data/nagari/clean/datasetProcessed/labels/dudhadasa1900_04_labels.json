            "x1": 124,
            "y1": 820,
            "x2": 1689,
            "y2": 950
        }
    },
    {
        "line_number": 11,
        "text": "दो० विपिन बास सुनि विकलभइँ गिरिनंदिनी खगेश ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_11.png",
