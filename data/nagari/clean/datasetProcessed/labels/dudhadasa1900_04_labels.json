            "y1": 2211,
            "x2": 1697,
            "y2": 2331
        }
    },
    {
        "line_number": 26,
        "text": "जो रुचिप्रिय तुम्हरे उर होई । मांगहु बेगि देउँ बर सोई ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_04_textline_26.png",
