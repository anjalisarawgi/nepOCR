    },
    {
        "line_number": 3,
        "text": "बीते दिवस कछू यहि भांती । परमअनन्दअवध दिनराती ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_06_textline_3.png",
        "bounding_box": {
            "x1": 117,
            "y1": 146,
            "x2": 1736,
            "y2": 295
        }
    },
    {
        "line_number": 4,
        "text": "एक समय दशरथ कुलनायक । सुन्दरबदनश्यामसुखदायक ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_06_textline_4.png",
