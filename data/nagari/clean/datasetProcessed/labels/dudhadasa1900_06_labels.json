            "y2": 382
        }
    },
    {
        "line_number": 5,
        "text": "राज सभा शोभित रघुराजा । अनुजसहितपुरलोगसमाजा ॥",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_06_textline_5.png",
        "bounding_box": {
            "x1": 124,
            "y1": 361,
            "x2": 1742,
            "y2": 481
        }
    },
    {
        "line_number": 6,
        "text": "राजनीति मुनिराज सुनावें । सुनिप्रभुअनुजसहितसुखपावें ।।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_06_textline_6.png",
        "bounding_box": {
            "x1": 124,
            "y1": 447,
            "x2": 1726,
            "y2": 567
        }
    },
    {
        "line_number": 7,
        "text": "और विविध इतिहास पुराना । कहैं वशिष्ठ सुनैं भगवाना ।।",
