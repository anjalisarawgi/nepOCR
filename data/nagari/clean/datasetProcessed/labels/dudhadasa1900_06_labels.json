            "x1": 124,
            "y1": 538,
            "x2": 1726,
            "y2": 666
        }
    },
    {
        "line_number": 8,
        "text": "दो० त्यहिअवसर यकदूत तहँ खबरि सुनायो आय ।",
        "image_path": "datasetProcessed/cropped_textlines/images/dudhadasa1900_06_textline_8.png",
        "bounding_box": {
